{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "resource.schema.json",
  "title": "F5 XC Console Resource Mapping",
  "description": "Maps an API resource to its console locations, forms, and operations — the traceability matrix",
  "type": "object",
  "properties": {
    "schema": {
      "type": "string",
      "const": "urn:xcsh:console:resource:v1"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "label": {
      "type": "string"
    },
    "api": {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string",
          "description": "API resource kind (snake_case, matches api-specs-enriched)"
        },
        "group": {
          "type": "string",
          "description": "API group (e.g., ves.io.schema.views)"
        },
        "version": {
          "type": "string"
        },
        "api_spec_file": {
          "type": "string",
          "description": "Reference to OpenAPI spec file in api-specs-enriched"
        },
        "crud_endpoints": {
          "type": "object",
          "properties": {
            "create": { "type": "string" },
            "read": { "type": "string" },
            "update": { "type": "string" },
            "delete": { "type": "string" },
            "list": { "type": "string" }
          }
        }
      },
      "required": ["kind"]
    },
    "console": {
      "type": "object",
      "properties": {
        "workspace": {
          "type": "string",
          "description": "Workspace ID (e.g., web-app-and-api-protection)"
        },
        "workspace_label": {
          "type": "string"
        },
        "route_prefix": {
          "type": "string",
          "description": "Workspace URL prefix"
        },
        "route_pattern": {
          "type": "string",
          "description": "URL path relative to workspace prefix"
        },
        "list_route": {
          "type": "string",
          "description": "Relative path to route YAML (legacy)"
        },
        "detail_route_pattern": {
          "type": "string"
        },
        "create_route_pattern": {
          "type": "string"
        },
        "menu_path": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Sidebar navigation path"
        },
        "breadcrumbs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "namespace_scoped": {
          "type": "boolean",
          "description": "False for system-level resources like namespace"
        },
        "navigation": {
          "type": "object",
          "properties": {
            "menu_path": {
              "type": "array",
              "items": { "type": "string" }
            },
            "product_area": {
              "type": "string"
            }
          }
        }
      }
    },
    "workflows": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "description": "Relative path to workflow YAML"
      },
      "description": "Map of operation name to workflow file path"
    },
    "form": {
      "type": "object",
      "properties": {
        "sections": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/form_section"
          }
        }
      }
    },
    "metadata": {
      "$ref": "common.schema.json#/definitions/metadata"
    }
  },
  "required": ["schema", "id", "label", "api", "console"],
  "definitions": {
    "form_section": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "type": {
          "type": "string",
          "enum": ["default", "nested-resource-list", "tab", "accordion", "drawer"],
          "default": "default"
        },
        "description": { "type": "string" },
        "collapsible": { "type": "boolean" },
        "initially_collapsed": { "type": "boolean" },
        "show_advanced_fields": {
          "type": "boolean",
          "description": "True if section has a Show Advanced Fields toggle"
        },
        "add_action": {
          "type": "string",
          "description": "Button label for adding items (e.g., Add Item, Add Label)"
        },
        "nested_resource": {
          "type": "string",
          "description": "Resource ID if this section manages nested resources"
        },
        "fields": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/form_field"
          }
        }
      },
      "required": ["id", "label"]
    },
    "form_field": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "type": {
          "type": "string",
          "enum": [
            "text",
            "textbox",
            "textarea",
            "number",
            "spinbutton",
            "select",
            "listbox",
            "multi-select",
            "checkbox",
            "toggle",
            "switch",
            "radio",
            "date",
            "json",
            "string-list",
            "key-value-pairs",
            "table",
            "resource-selector",
            "nested-resource-list",
            "configurable",
            "expandable",
            "file-upload",
            "code-editor",
            "disabled"
          ]
        },
        "required": { "type": "boolean" },
        "default": {},
        "description": { "type": "string" },
        "help_text": {
          "type": "string",
          "description": "Tooltip or help text shown in the console UI"
        },
        "advanced": {
          "type": "boolean",
          "description": "True if field is hidden behind Show Advanced Fields toggle"
        },
        "api_field": {
          "type": "string",
          "description": "Dot-notation path to the corresponding API field (legacy)"
        },
        "api_path": {
          "type": "string",
          "description": "Full API property path from JSON tab (e.g., spec.default_route_pools[].pool)"
        },
        "options": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Available options for select/radio fields"
        },
        "resource_type": {
          "type": "string",
          "description": "Resource ID for resource-selector fields"
        },
        "selector": { "type": "string" },
        "validation": {
          "type": "object",
          "properties": {
            "pattern": { "type": "string" },
            "min_length": { "type": "integer" },
            "max_length": { "type": "integer" },
            "min": { "type": "number" },
            "max": { "type": "number" }
          }
        },
        "show_when": {
          "type": "object",
          "description": "Conditional visibility — field shown only when another field matches a value",
          "properties": {
            "field": {
              "type": "string",
              "description": "ID of the controlling field"
            },
            "equals": {
              "description": "Value(s) that make this field visible",
              "oneOf": [{ "type": "string" }, { "type": "array", "items": { "type": "string" } }]
            },
            "not_equals": {
              "description": "Value(s) that hide this field",
              "oneOf": [{ "type": "string" }, { "type": "array", "items": { "type": "string" } }]
            }
          },
          "required": ["field"]
        },
        "nested_form": {
          "type": "object",
          "description": "Sub-form that opens when clicking Configure, Edit, or Add Item",
          "properties": {
            "trigger": {
              "type": "string",
              "enum": ["configure", "add-item", "edit", "select-value"],
              "description": "What interaction opens this nested form"
            },
            "trigger_value": {
              "type": "string",
              "description": "Specific value that triggers the nested form (for select-value trigger)"
            },
            "fields": {
              "type": "array",
              "items": { "$ref": "#/definitions/form_field" },
              "description": "Fields within the nested form (recursive)"
            }
          }
        },
        "item_types": {
          "type": "object",
          "description": "Discriminated array item types — different field sets per item type selection",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "fields": {
                "type": "array",
                "items": { "$ref": "#/definitions/form_field" }
              },
              "description": { "type": "string" }
            }
          }
        },
        "min_items": {
          "type": "integer",
          "description": "Minimum number of items for array/list fields"
        },
        "max_items": {
          "type": "integer",
          "description": "Maximum number of items for array/list fields"
        }
      },
      "required": ["id", "label", "type"]
    }
  }
}
